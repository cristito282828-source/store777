# ==============================================================================
# CONFIGURACIÓN DEL SITIO - EJEMPLO DE TIENDA
# ==============================================================================

# Nombre de la compañía
COMPANY_NAME="Example Store"

# Nombre del sitio
SITE_NAME="Example Store - Tu Tienda Online de WooCommerce"
NEXT_PUBLIC_SITE_NAME="Example Store"

# URL completa del sitio en producción (sin trailing slash)
SITE_URL="https://example.com"
NEXT_PUBLIC_SITE_URL="https://example.com"

# ==============================================================================
# WOOCOMMERCE GRAPHQL API (REQUERIDO)
# ==============================================================================

# URL de tu sitio WooCommerce
NEXT_PUBLIC_WOOCOMMERCE_URL="https://your-woocommerce-site.com"

# Consumer Key para la API de WooCommerce
# Obtenerlo en: WooCommerce > Ajustes > Avanzado > REST API > Agregar clave
# Permisos necesarios: Leer (Read)
NEXT_PUBLIC_WOOCOMMERCE_CONSUMER_KEY="ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Consumer Secret para la API de WooCommerce
NEXT_PUBLIC_WOOCOMMERCE_CONSUMER_SECRET="cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ==============================================================================
# CONTACTO Y CHECKOUT
# ==============================================================================

# Número de teléfono para WhatsApp checkout (formato: código país + número, sin símbolos)
# Ejemplo: 56900000000 para +56 9 0000 0000
NEXT_PUBLIC_PHONE_NUMBER="56900000000"

# Email de contacto
NEXT_PUBLIC_CONTACT_EMAIL="hello@example.com"

# ==============================================================================
# CONFIGURACIÓN DE GOOGLE ANALYTICS (OPCIONAL)
# ==============================================================================

# Google Analytics ID
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ==============================================================================
# CONFIGURACIÓN DE SENTRY (OPCIONAL - RECOMENDADO PARA PRODUCCIÓN)
# ==============================================================================

# DSN público de Sentry (obtenerlo en https://sentry.io/)
# NEXT_PUBLIC_SENTRY_DSN="https://your_key@sentry.io/your_project_id"

# Organización en Sentry (para subir source maps)
# SENTRY_ORG="your-sentry-org"

# Proyecto en Sentry
# SENTRY_PROJECT="pinneacle-perfumeria"

# Token de autenticación para subir source maps
# SENTRY_AUTH_TOKEN="your_sentry_auth_token"

# ==============================================================================
# CONFIGURACIÓN DE DESARROLLO
# ==============================================================================

# Entorno de Node.js (no modificar manualmente)
# NODE_ENV="development"
https://dev-pinneacle.pantheonsite.io/wp-login.php
